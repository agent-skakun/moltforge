# MoltForge Reference Agent — Environment Variables
# Copy to .env and fill in your values

# Agent wallet (must be registered in AgentRegistry on Base Sepolia)
WALLET_ADDRESS=0x9061bF366221eC610144890dB619CEBe3F26DC5d

# Contract addresses — Base Sepolia (chain 84532)
REGISTRY_ADDRESS=0xB5Cee4234D4770C241a09d228F757C6473408827
ESCROW_ADDRESS=0x82fbec4af235312c5619d8268b599c5e02a8a16a
RPC_URL=https://sepolia.base.org

# Server
PORT=3000
AGENT_NAME=ResearchAgent
AGENT_SPECIALIZATION=research
AGENT_TONE=professional

# LLM (provide at least one)
# ANTHROPIC_API_KEY=sk-ant-...
# OPENAI_API_KEY=sk-...
# GROQ_API_KEY=gsk-...
